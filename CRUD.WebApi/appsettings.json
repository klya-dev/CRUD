{
  "Kestrel": {
    "Endpoints": { // Если собрать приложение, то предупреждения "Overriding address(es)..." не будет, т.к оно возникает из-за launchSettings.json. И теперь порт можно легко менять
      "Https": {
        "Url": "https://localhost:7260",
        "Protocols": "Http1AndHttp2"
      },
      "Http": {
        "Url": "http://localhost:5171",
        "Protocols": "Http1" // Kestrel позволяет использовать HTTP/2 без сертификата TLS. Например, для gRPC HTTP/2 обязателен. Т.к в основном HTTPS nginx проксирует на HTTP kestrel это хороший плюс Kestrel
      }
    }
  },
  "Program": {
    "SkipLogging": false,
    "SkipInitializers": false
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "CRUD.WebApi.Middlewares.UsefulBadRequestMiddleware": "Debug",
        "Grpc.Net.Client.Internal.GrpcCall": "Error"
      }
    },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithProcessId", "WithThreadId" ],
    "Properties": {
      "ApplicationName": "CRUD" // Кастомное свойство, можно использовать в template в Program.cs
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "CONFIGURED_IN_SECRETS_MANAGER",
    "RedisConnection": "CONFIGURED_IN_SECRETS_MANAGER",
    "RabbitMqConnection": "CONFIGURED_IN_SECRETS_MANAGER"
  },
  "SmsSender": {
    "ServiceURL": "CONFIGURED_IN_SECRETS_MANAGER",
    "Email": "CONFIGURED_IN_SECRETS_MANAGER",
    "ApiKey": "CONFIGURED_IN_SECRETS_MANAGER",
    "Sign": "CONFIGURED_IN_SECRETS_MANAGER"
  },
  "TelegramIntegration": {
    "ServiceURL": "CONFIGURED_IN_SECRETS_MANAGER",
    "ApiKey": "CONFIGURED_IN_SECRETS_MANAGER",
    "TimeToLive": 0 // CONFIGURED_IN_SECRETS_MANAGER
  },
  "PayManager": {
    "ServiceURL": "CONFIGURED_IN_SECRETS_MANAGER",
    "ShopId": "CONFIGURED_IN_SECRETS_MANAGER",
    "ApiKey": "CONFIGURED_IN_SECRETS_MANAGER",
    "SafeListIp": "CONFIGURED_IN_SECRETS_MANAGER"
  },
  "OAuthMailRu": {
    "ClientId": "CONFIGURED_IN_SECRETS_MANAGER",
    "ClientSecret": "CONFIGURED_IN_SECRETS_MANAGER",
    "RedirectUri": "CONFIGURED_IN_SECRETS_MANAGER",
    "OpenIdConfigurationUrl": "CONFIGURED_IN_SECRETS_MANAGER"
  },
  "S3": {
    "AccessKey": "CONFIGURED_IN_SECRETS_MANAGER",
    "SecretKey": "CONFIGURED_IN_SECRETS_MANAGER",
    "BucketName": "CONFIGURED_IN_SECRETS_MANAGER",
    "ServiceURL": "CONFIGURED_IN_SECRETS_MANAGER",
    "LogsDirectory": "Logs",
    "LogsInS3Directory": "WebApi/Logs"
  },
  "S3Initializer": {
    "ArchiveInS3Directory": "archive"
  },
  "EmailSender": {
    "ServiceURL": "https://localhost:7261",
    "HealthzEndpoint": "healthz",
    "UseUnixDomainSocketGRPC": true,
    "FileNameInTempFolder": "socket.tmp"
  },
  "AvatarManager": {
    "AvatarsInS3Directory": "avatars",
    "DefaultAvatarPath": "avatars/default.png",
    "MaxFileSize": 10485760, // 10 МБ
    "MaxFileSizeString": "10" // 10 MB/МБ в зависимости от локализации
  },
  "Auth": { // Основные параметры аутентификации (можно менять на лету)
    "PrivateKeyPath": "E:\\Projects\\Web\\CRUD\\secrets\\private_key.pem",
    "PublicKeyPath": "E:\\Projects\\Web\\CRUD\\secrets\\public_key.pem",
    "KeyId": "key-v1",
    "Issuer": "https://localhost:7260"
  },
  "AuthWebApi": { // Параметры WebApi аутентификации (можно менять на лету)
    "Audience": "https://localhost:7260",
    "Expires": "00:10:00", // 10 минут
    "ExpiresRefreshToken": "7.00:00:00", // 7 дней
    "MaxCountRefreshTokens": 3
  },
  "AuthEmailSender": { // Параметры EmailSender аутентификации (можно менять на лету)
    "Audience": "https://localhost:7261",
    "Expires": "00:10:00"
  },
  "BackgroundServices": {
    "SaveLogsToS3BackgroundService": {
      "Timer": "1.00:00:00"
    },
    "DeleteExpiredRequestsBackgroundService": {
      "Timer": "1.00:00:00"
    },
    "RevokeExpiredRefreshTokensBackgroundService": {
      "Timer": "00:10:00"
    }
  },
  "Requests": {
    "ChangePasswordRequest": {
      "Expires": "00:07:00",
      "Timeout": "00:01:00"
    },
    "ConfirmEmailRequest": {
      "Expires": "00:10:00",
      "Timeout": "00:01:00"
    },
    "VerificationPhoneNumberRequest": {
      "Expires": "00:10:00",
      "Timeout": "00:10:00",
      "LengthCode": 6
    }
  },
  "RateLimiter": {
    "Global": { // Небольше 50 запросов в минуту
      "PermitLimit": 50,
      "Window": 60,
      "QueueLimit": 0
    },
    "PublicationsGet": { // Небольше 100 запросов в минуту
      "PermitLimit": 100,
      "Window": 60,
      "QueueLimit": 0
    }
  },
  "Metrics": {
    "PrometheusURL": "http://localhost:9090"
  },
  "Clients": {
    "WebClientURLs": [ "https://localhost:7217" ]
  },
  "Tuna": "https://ucx..." // Для KnownProxies (ForwardedHeaders), сюда впихиваешь url, а в коде я сам достану IP и добавлю в список | Это пример удалённого прокси-сервера, если будет использоваться прокси на одной машине с приложением, то это не нужно
  // Пока что, Tuna нужна для двух случаев, 1) для ЮКассы (вебхук), но указать URL в коде не получится только через их сайт https://yookassa.ru/my/merchant/integration/http-notifications
  // И, 2) чтобы добавить в KnownProxies. Т.к это удалённый прокси и нужно указывать приложению, какому прокси он будет доверять
}